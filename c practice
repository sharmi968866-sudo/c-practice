// DIVIDE AND MULTIPLE

#include<stdio.h>
void main()
{
    int num1,num2;
    printf("Enter two numbers:");
    scanf("%d %d",&num1,&num2);
    printf("%d/%d=%d\n",num1,num2,num1/num2);
    printf("%d*%d=%d\n",num1,num2,num1*num2);
}

